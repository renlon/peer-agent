#!/usr/bin/env python3

from __future__ import annotations

import shutil
import sys
import tempfile
from pathlib import Path

SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

from peer_agent_common import (
    artifact_path,
    artifact_metadata,
    capture_target_snapshot,
    choose_exec_cwd,
    fail_with_log,
    parse_args,
    render_prompt,
    resolve_target,
    run_with_input,
    write_artifact,
    write_artifact_metadata,
)


def main() -> int:
    if shutil.which("codex") is None:
        sys.stderr.write("codex is not available on PATH\n")
        return 127

    args = parse_args("codex")
    requested_cwd = Path(args.cwd).expanduser().resolve() if args.cwd else Path.cwd()
    try:
        target = resolve_target(args.target, requested_cwd)
    except (FileNotFoundError, ValueError) as exc:
        sys.stderr.write(f"{exc}\n")
        return 2
    snapshot = capture_target_snapshot(target)
    instruction = " ".join(args.instruction).strip()
    prompt = render_prompt(args.action, "claude", requested_cwd, target, instruction, snapshot)
    exec_cwd = choose_exec_cwd(args.action, requested_cwd, target)

    with tempfile.NamedTemporaryFile(prefix="ask-codex-", suffix=".txt", delete=False) as tmp:
        output_path = Path(tmp.name)

    command = [
        "codex",
        "exec",
        "--ephemeral",
        "--skip-git-repo-check",
        "-C",
        str(exec_cwd),
        "-o",
        str(output_path),
        "-",
    ]
    if args.action == "edit":
        command += ["-s", "workspace-write"]
    else:
        command += ["-s", "read-only"]

    result = run_with_input(command, cwd=exec_cwd, stdin_text=prompt)
    stdout_text = output_path.read_text(encoding="utf-8", errors="replace") if output_path.exists() else ""
    output_path.unlink(missing_ok=True)

    if result.returncode != 0:
        return fail_with_log(
            peer="codex",
            action=args.action,
            target=target,
            snapshot=snapshot,
            requested_cwd=requested_cwd,
            exec_cwd=exec_cwd,
            command=command,
            stdout=stdout_text or result.stdout,
            stderr=result.stderr,
            returncode=result.returncode,
        )

    if not args.no_save:
        path = artifact_path(args.action, "codex", target, snapshot)
        write_artifact(path, stdout_text)
        write_artifact_metadata(
            path,
            artifact_metadata(
                peer="codex",
                action=args.action,
                target=target,
                snapshot=snapshot,
                requested_cwd=requested_cwd,
                exec_cwd=exec_cwd,
            ),
        )

    sys.stdout.write(stdout_text)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
